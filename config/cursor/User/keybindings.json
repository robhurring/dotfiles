[
  {
    "key": "ctrl+space",
    "command": "workbench.action.quickOpen",
    "when": "editorTextFocus && vim.mode == 'Normal'"
  },
  {
    "key": "ctrl+p",
    "command": "editor.action.peekDefinition",
    "when": "editorTextFocus && vim.mode == 'Normal'"
  },
  {
    "key": "ctrl+q",
    "command": "workbench.action.closeActiveEditor",
    "when": "editorTextFocus"
  },
  {
    "key": "tab",
    "command": "editor.action.showHover",
    "when": "editorTextFocus && vim.mode == 'Normal' && !suggestWidgetVisible"
  },
  {
    "key": "shift+tab",
    "command": "editor.action.quickFix",
    "when": "editorTextFocus && vim.mode == 'Normal' && !suggestWidgetVisible"
  },
  {
    "key": "shift+r",
    "command": "editor.action.refactor",
    "when": "editorTextFocus && vim.mode == 'Normal'"
  },
  {
    "key": "cmd+1",
    "command": "workbench.action.toggleSidebarVisibility"
  },
  {
    "key": "shift+f6",
    "command": "editor.action.rename",
    "when": "editorTextFocus"
  },
  {
    "key": "alt+cmd+s",
    "command": "workbench.action.toggleUnifiedSidebarFromKeyboard",
    "when": "cursor.agentIdeUnification.enabled == true && !isAuxiliaryWindowFocusedContext"
  },
  {
    "key": "ctrl+j",
    "command": "selectNextSuggestion",
    "when": "suggestWidgetVisible"
  },
  {
    "key": "ctrl+k",
    "command": "selectPrevSuggestion",
    "when": "suggestWidgetVisible"
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.quickOpenSelectNext",
    "when": "inQuickOpen"
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.quickOpenSelectPrevious",
    "when": "inQuickOpen"
  },
  {
    "key": "ctrl+h",
    "command": "workbench.action.focusLeftGroup",
    "when": "editorTextFocus && vim.mode == 'Normal' && !suggestWidgetVisible && !inQuickOpen"
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.focusBelowGroup",
    "when": "editorTextFocus && vim.mode == 'Normal' && !suggestWidgetVisible && !inQuickOpen"
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.focusAboveGroup",
    "when": "editorTextFocus && vim.mode == 'Normal' && !suggestWidgetVisible && !inQuickOpen"
  },
  {
    "key": "ctrl+l",
    "command": "workbench.action.focusRightGroup",
    "when": "editorTextFocus && vim.mode == 'Normal' && !suggestWidgetVisible && !inQuickOpen"
  },
  {
    "key": "cmd+r",
    "command": "workbench.action.debug.selectandstart"
  },
  {
    "key": "f7",
    "command": "workbench.action.debug.stepInto",
    "when": "inDebugMode"
  },
  {
    "key": "f8",
    "command": "workbench.action.debug.stepOver",
    "when": "inDebugMode"
  },
  {
    "key": "f9",
    "command": "workbench.action.debug.continue",
    "when": "inDebugMode"
  },
  {
    "key": "alt+shift+f8",
    "command": "workbench.action.debug.stepOver",
    "when": "inDebugMode && debugState == 'stopped'"
  },
  {
    "key": "shift+f7",
    "command": "workbench.action.debug.stepInto",
    "when": "inDebugMode && debugState == 'stopped'"
  },
  {
    "key": "shift+f8",
    "command": "workbench.action.debug.stepOut",
    "when": "inDebugMode"
  }
]
